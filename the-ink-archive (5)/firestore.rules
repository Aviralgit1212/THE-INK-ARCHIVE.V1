rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /pieces/{slug} {
      // Allow read access for published pieces to anyone; draft pieces require authentication
      allow read: if resource == null || resource.data.isDraft != true || request.auth != null;
      
      // Allow creation only if authenticated
      allow create: if request.auth != null;
      
      // Allow deletion only if authenticated
      allow delete: if request.auth != null;
      
      // Allow update:
      // 1. If authenticated (full edit)
      // 2. If unauthenticated, but ONLY updating the 'views' field (for incrementViews)
      allow update: if request.auth != null || (
        resource.data.isDraft != true && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])
      );
    }
  }
}
